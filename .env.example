# OpenRouter API key for LLM-powered report extraction (optional)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Path to infrastructure CSV (used by backend)
DATA_PATH=./data/infrastructure.csv

# Frontend: backend base URL for API calls
# Set to your deployed DigitalOcean backend URL in production.
# Leave unset for local dev (defaults to http://localhost:8080).
VITE_API_URL=https://your-backend-url
